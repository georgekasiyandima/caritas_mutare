# =============================================================================
# Caritas Mutare API — environment variables
# =============================================================================
# Copy this file to `.env` for local development. In production (Render)
# set each of these in the Render dashboard under "Environment" — never
# commit a populated .env file.
# -----------------------------------------------------------------------------

# ---- Core ------------------------------------------------------------------
PORT=5000
# development | production | test
NODE_ENV=development

# ---- Database --------------------------------------------------------------
# Local dev uses SQLite. Leave DATABASE_URL empty and the server writes to
# server/database.sqlite (path can be overridden with DATABASE_PATH).
DATABASE_PATH=./database.sqlite

# Production: set DATABASE_URL to the full Postgres connection string from
# Neon / Supabase / Render Postgres, e.g.:
#   postgres://user:pass@ep-foo-bar.eu-central-1.aws.neon.tech/caritas?sslmode=require
# When this is set AND NODE_ENV=production, the API uses Postgres via Knex.
# DATABASE_URL=

# ---- Authentication --------------------------------------------------------
# MUST be set in production. Generate with:   openssl rand -hex 48
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=7d

# ---- CORS ------------------------------------------------------------------
# Comma-separated list of allowed origins for the deployed frontend(s).
# Example (production):
#   CLIENT_URL=https://caritas-mutare.vercel.app,https://www.caritasmutare.org
# Local dev always allows http://localhost:3000 regardless of this value.
CLIENT_URL=http://localhost:3000

# Set to `true` to also allow requests from any *.vercel.app preview URL.
# Handy while iterating; disable once you have the final domains wired up.
ALLOW_VERCEL_PREVIEWS=false

# ---- Seeds / Bootstrap -----------------------------------------------------
# In production, seeds do NOT run on boot unless you opt in. When set to
# `true`, the seed file will run once per deploy and bootstrap the first
# admin (only if one doesn't already exist) using the values below.
RUN_SEEDS_ON_BOOT=false

# First admin user (production only — ignored if an admin already exists).
# Alternative to running server/scripts/create-admin.js manually.
# BOOTSTRAP_ADMIN_USERNAME=angela
# BOOTSTRAP_ADMIN_EMAIL=angela@caritasmutare.org
# BOOTSTRAP_ADMIN_PASSWORD=generate-a-long-random-one

# ---- File uploads ----------------------------------------------------------
# NOTE: Render's free tier has an ephemeral filesystem — files under ./uploads
# will be wiped on every deploy. We'll swap to Cloudflare R2 in the next
# wave; until then, don't rely on uploads persisting across deploys.
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ---- Transactional email (not yet wired, reserved for Resend) --------------
# RESEND_API_KEY=
# EMAIL_FROM=no-reply@caritasmutare.org

# ---- Payments (reserved) ---------------------------------------------------
# PAYMENT_GATEWAY_API_KEY=
# PAYMENT_GATEWAY_SECRET=

# ---- Analytics -------------------------------------------------------------
# GOOGLE_ANALYTICS_ID=
